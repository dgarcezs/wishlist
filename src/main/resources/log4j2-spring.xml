<?xml version="1.0" encoding="UTF-8"?>
<Configuration>

  <Appenders>
    <Console name="Console" target="SYSTEM_OUT">
      <PatternLayout
        pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level traceId=%X{traceId} spanId=%X{spanId} [%t] %c{1} - %msg%n"/>
    </Console>
  </Appenders>

  <Loggers>
    <AsyncRoot level="INFO">
      <AppenderRef ref="Console"/>
    </AsyncRoot>
  </Loggers>

</Configuration>